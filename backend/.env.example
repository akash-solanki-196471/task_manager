PORT=5001

# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/taskmanager

# MongoDB Atlas (production — replace <user>, <password>, <cluster>):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/taskmanager?retryWrites=true&w=majority

JWT_SECRET=your-super-secret-jwt-key-change-this-please

NODE_ENV=development

# CORS — comma-separated list of allowed origins (production: CloudFront + custom domain)
# Leave empty or omit in dev (defaults to http://localhost:4200)
# ALLOWED_ORIGINS=https://yourdomain.com,https://dXXXXXXXXXXXX.cloudfront.net
